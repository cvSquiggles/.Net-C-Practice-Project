@{/*Revised view to work with styling generated by AI tools*/}

@model IEnumerable<HelloWorld.Models.Book>
@{
    /*Populate title for view*/
    ViewData["Title"] = "Collection";
}

<h1 class="page-title">Collection</h1>

@if (!Model.Any())
{
    <div class="empty-state">
        <p>No books in your library yet.</p>
        <a href="/Books/Create" class="btn btn-primary">Add your first book</a>
    </div>
}
else
{
    <div class="book-list">
        @foreach (var book in Model)
        {
            <div class="book-item">
                <div>
                    <div class="book-item-title">
                        <a href="/Books/Details/@book.Id">@book.Title</a>
                    </div>
                    <div class="book-item-author">@book.Author</div>
                </div>
                <div class="book-item-genre">@book.Genre</div>
                <div class="book-item-year">@book.PublicationYear</div>
                <span class="status-badge status-@book.ReadingStatus.ToLower()">@book.ReadingStatus</span>
                <div class="book-item-actions">
                    <a href="/Books/Edit/@book.Id" class="btn btn-sm">Edit</a>
                    @{/*Html.AntiForgeryToken() is a security measure that embeds a unique token in the clients cookies, and we authenticate it when the form is submitted to verify it's coming from the client we served the form to originally. */}
                    <form method="post" action="/Books/Delete/@book.Id" style="display:inline"
                          onsubmit="return confirm('Remove @book.Title?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                    </form>
                </div>
            </div>
        }
    </div>
}